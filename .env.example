# Finetune Agent - environment configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored, so your real keys are never committed.
# Anything you set in your shell still overrides these (override=False).

# ---------------------------------------------------------------------------
# Which LLM backend to use: "openai" | "ollama" | "mock"
#   - "openai" works for OpenAI AND any OpenAI-compatible API (e.g. Groq).
#   - "mock"   uses canned/templated output (no real model) -- the default.
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# Groq (free, OpenAI-compatible). Set LLM_PROVIDER=openai to use these.
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# OpenAI proper (alternative to Groq). If set, OPENAI_API_KEY takes
# precedence over GROQ_API_KEY. Leave OPENAI_BASE_URL unset (or remove it)
# to hit api.openai.com. Example model: gpt-4o-mini
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Ollama (local models). Only used when LLM_PROVIDER=ollama.
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder

# ---------------------------------------------------------------------------
# Optional: Redis-backed memory store. If unset, a local file store is used.
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
